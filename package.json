{
  "name": "sistema-gestion-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "author": "Maximo Lavagetto",
  "license": "MIT",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "frontend:install": "npm --prefix frontend-react install",
    "frontend:build": "npm --prefix frontend-react run build",
    "backend:install": "npm --prefix backend/server install",
    "cloud:install": "npm --prefix cloud install",
    "cloud:dev": "npm --prefix cloud run dev",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --win",
    "desktop:build": "npm run frontend:build && npm run electron:build"
  },
  "dependencies": {
    "@sendgrid/mail": "^7.7.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "fast-xml-parser": "^5.3.3",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.6",
    "pdfkit": "^0.13.0",
    "pg": "^8.11.5",
    "qrcode": "^1.5.4",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.sistema.gestion",
    "productName": "SistemaGestion",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**",
      "frontend-react/dist/**",
      "backend/server/**",
      "backend/database/migrations_sqlite/**",
      "backend/database/seed.sql",
      "!backend/server/node_modules/**",
      "!backend/server/.env",
      "!backend/server/.env.*",
      "!backend/server/logs/**",
      "!backend/server/**/*.log"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/bcrypt/**"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
